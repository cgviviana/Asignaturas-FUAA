function ejecutarNota() {
    const nota = Number(document.getElementById("inputNota").value);
    const salida = document.getElementById("salida");

    if (Number.isNaN(nota)) {
        salida.innerHTML = "> Ingresa una nota válida.";
    } else if (nota >= 3.0) {
        salida.innerHTML = "> Aprueba.";
    } else {
        salida.innerHTML = "> No aprueba.";
    }
}

function ejecutarEscanerBasico() {
    const salida = document.getElementById("salida");
    let documentos = 5;
    salida.innerHTML = "";

    const intervalo = setInterval(() => {
        if (documentos > 0) {
            salida.innerHTML += "> Documento escaneado. Faltan: " + documentos + "<br>";
            documentos--;
        } else {
            salida.innerHTML += "> Escaneo terminado.";
            clearInterval(intervalo);
        }
    }, 550);
}

function ejecutarRespuestaBasica() {
    const r = document.getElementById("inputRespuestaBasica").value.toLowerCase();
    const salida = document.getElementById("salida");

    if (r === "si" || r === "no") {
        salida.innerHTML = "> Respuesta aceptada.";
    } else {
        salida.innerHTML = "> Respuesta no válida. Debe escribir si o no.";
    }
}

function ejecutarServicioBasico() {
    const op = document.getElementById("opcionServicio").value;
    const salida = document.getElementById("salida");

    if (op === "1") salida.innerHTML = "> Servicio de certificados.";
    else if (op === "2") salida.innerHTML = "> Servicio de pagos.";
    else if (op === "3") salida.innerHTML = "> Servicio de soporte.";
    else salida.innerHTML = "> Opción no válida.";
}

function ejecutarClasificarNumero() {
    const n = Number(document.getElementById("inputNumeroClasificar").value);
    const salida = document.getElementById("salida");

    if (Number.isNaN(n)) {
        salida.innerHTML = "> Ingresa un número válido.";
    } else if (n > 0) {
        salida.innerHTML = "> El número es positivo.";
    } else if (n < 0) {
        salida.innerHTML = "> El número es negativo.";
    } else {
        salida.innerHTML = "> El número es cero.";
    }
}

function ejecutarNumeros() {
    const salida = document.getElementById("salida");
    salida.innerHTML = "";
    let i = 1;
    const intervalo = setInterval(() => {
        salida.innerHTML += i + " ";
        i++;
        if (i > 100) {
            salida.innerHTML += "<br>> Conteo terminado.";
            clearInterval(intervalo);
        }
    }, 35);
}

function ejecutarParImpar() {
    const numero = Number(document.getElementById("inputNumero").value);
    const salida = document.getElementById("salida");
    if (Number.isNaN(numero)) {
        salida.innerHTML = "> Ingresa un número válido.";
        return;
    }
    salida.innerHTML = numero % 2 === 0 ? "> El número es par." : "> El número es impar.";
}

function ejecutarEdades() {
    const salida = document.getElementById("salida");
    const edades = [18, 22, 31, 45, 16];
    let i = 0;
    salida.innerHTML = "";

    const intervalo = setInterval(() => {
        salida.innerHTML += "> Persona " + (i + 1) + ": " + edades[i] + " años<br>";
        i++;

        if (i === edades.length) {
            salida.innerHTML += "> Registro simulado terminado.";
            clearInterval(intervalo);
        }
    }, 500);
}

function ejecutarEdad() {
    const edad = Number(document.getElementById("inputEdad").value);
    const salida = document.getElementById("salida");
    if (Number.isNaN(edad)) {
        salida.innerHTML = "> Ingresa una edad válida.";
        return;
    }
    salida.innerHTML = edad >= 18 ? "> Es mayor de edad." : "> Es menor de edad.";
}

function agregarProducto() {
    const precio = Number(document.getElementById("inputPrecio").value);
    const salida = document.getElementById("salida");
    if (Number.isNaN(precio) || precio <= 0) {
        salida.innerHTML = "> Ingresa un precio válido.";
        return;
    }
    totalCarrito += precio;
    salida.innerHTML = "> Producto agregado. Total actual: " + totalCarrito;
}

function finalizarCarrito() {
    document.getElementById("salida").innerHTML = "> Total final a pagar: " + totalCarrito;
}

function ejecutarPromedio() {
    const salida = document.getElementById("salida");
    const notas = [4.0, 3.5, 5.0, 4.2, 3.8];
    let suma = 0;
    let i = 0;
    salida.innerHTML = "";
    const intervalo = setInterval(() => {
        suma += notas[i];
        salida.innerHTML += "> Nota " + (i + 1) + ": " + notas[i] + "<br>";
        i++;
        if (i === notas.length) {
            salida.innerHTML += "> Promedio simulado: " + (suma / notas.length).toFixed(2);
            clearInterval(intervalo);
        }
    }, 600);
}

function ejecutarSensor() {
    const salida = document.getElementById("salida");
    const mediciones = [30, 32, 35, 38, 41];
    let i = 0;
    salida.innerHTML = "";
    const intervalo = setInterval(() => {
        if (mediciones[i] <= 40) {
            salida.innerHTML += "> Temperatura normal: " + mediciones[i] + "°C<br>";
        } else {
            salida.innerHTML += "> Alerta: temperatura alta (" + mediciones[i] + "°C).";
            clearInterval(intervalo);
        }
        i++;
    }, 650);
}

function ejecutarEnvio() {
    const op = document.getElementById("opcionEnvio").value;
    const salida = document.getElementById("salida");
    if (op === "1") salida.innerHTML = "> Envío estándar seleccionado.";
    else if (op === "2") salida.innerHTML = "> Envío rápido seleccionado.";
    else if (op === "3") salida.innerHTML = "> Pago contraentrega seleccionado.";
    else salida.innerHTML = "> Recoger en tienda.";
}

function ejecutarCupos() {
    const salida = document.getElementById("salida");
    let cupos = Number(document.getElementById("inputCupos").value);

    if (Number.isNaN(cupos) || cupos <= 0) {
        salida.innerHTML = "> Ingresa una cantidad válida de cupos.";
        return;
    }

    salida.innerHTML = "";

    const intervalo = setInterval(() => {
        if (cupos > 0) {
            salida.innerHTML += "> Inscripción registrada. Cupos antes del registro: " + cupos + "<br>";
            cupos--;
        } else {
            salida.innerHTML += "> No quedan cupos disponibles.";
            clearInterval(intervalo);
        }
    }, 650);
}

function ejecutarInventario() {
    const salida = document.getElementById("salida");
    let stock = 10;
    salida.innerHTML = "";
    const intervalo = setInterval(() => {
        if (stock > 0) {
            salida.innerHTML += "> Venta realizada. Stock antes de vender: " + stock + "<br>";
            stock -= 2;
        } else {
            salida.innerHTML += "> Inventario agotado.";
            clearInterval(intervalo);
        }
    }, 600);
}

function ejecutarReporte() {
    const salida = document.getElementById("salida");
    let dia = 1;
    salida.innerHTML = "";
    const intervalo = setInterval(() => {
        salida.innerHTML += "> Reporte generado para día " + dia + "<br>";
        dia++;
        if (dia > 7) {
            salida.innerHTML += "> Semana completada.";
            clearInterval(intervalo);
        }
    }, 500);
}

function ejecutarDesempeno() {
    const puntaje = Number(document.getElementById("inputPuntaje").value);
    const salida = document.getElementById("salida");
    if (Number.isNaN(puntaje)) {
        salida.innerHTML = "> Ingresa un puntaje válido.";
        return;
    }
    if (puntaje < 60) salida.innerHTML = "> Desempeño bajo.";
    else if (puntaje < 90) salida.innerHTML = "> Desempeño medio.";
    else salida.innerHTML = "> Desempeño alto.";
}

function ejecutarHospital() {
    const op = document.getElementById("opcionHospital").value;
    const salida = document.getElementById("salida");
    if (op === "1") salida.innerHTML = "> Dirigir a urgencias.";
    else if (op === "2") salida.innerHTML = "> Dirigir a consulta externa.";
    else if (op === "3") salida.innerHTML = "> Dirigir a laboratorio.";
    else salida.innerHTML = "> Dirigir a farmacia.";
}

function ejecutarEncuesta() {
    const r = document.getElementById("inputEncuesta").value.toLowerCase();
    const salida = document.getElementById("salida");
    if (r === "si" || r === "no") salida.innerHTML = "> Respuesta registrada.";
    else salida.innerHTML = "> Respuesta no válida. Escribe si o no.";
}

function mezclarBotones(nivelId) {
    const nivel = document.getElementById(nivelId);
    if (!nivel) return;

    const botones = Array.from(nivel.querySelectorAll(".btn-choice"));
    for (let i = botones.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [botones[i], botones[j]] = [botones[j], botones[i]];
    }

    botones.forEach(btn => nivel.appendChild(btn));
}

mezclarBotones("nivelBasico");
mezclarBotones("nivelIntermedio");
mezclarBotones("nivelAvanzado");

function mezclarPistas() {
    const cont = document.getElementById("pistas");
    if (!cont) return;

    const titulo = document.getElementById("tituloPistas");
    const ayuda = document.getElementById("pistaAyuda");
    const items = Array.from(cont.querySelectorAll(".pista-item"));

    for (let i = items.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [items[i], items[j]] = [items[j], items[i]];
    }

    cont.innerHTML = "";
    cont.appendChild(titulo);
    items.forEach(item => cont.appendChild(item));
    cont.appendChild(ayuda);
}

mezclarPistas();


</script>

