function mostrarReto(id, boton) {
    retoActual = retos[id];
    botonActual = boton;

    document.querySelectorAll(".btn-choice").forEach(btn => btn.classList.remove("activo"));
    boton.classList.add("activo");

    document.getElementById("visual").style.display = "grid";
    document.getElementById("res-titulo").innerHTML = retoActual.titulo;
    document.getElementById("res-reto").innerHTML = retoActual.reto;
    document.getElementById("res-imagen").innerHTML = retoActual.imagen;
    prepararPistas();
    document.getElementById("selector").style.display = "block";
    document.getElementById("estructuraSelect").value = "";
    document.getElementById("botones").style.display = "none";
    document.getElementById("feedback").style.display = "none";
    document.getElementById("panel").style.display = "none";
    document.getElementById("panel").innerHTML = "";
}

function prepararPistas() {
    const pistas = document.getElementById("pistas");
    const ayuda = document.getElementById("pistaAyuda");
    const titulo = document.getElementById("tituloPistas");

    document.querySelectorAll('input[name="pista"]').forEach(chk => {
        chk.checked = false;
        chk.disabled = false;
    });

    ayuda.style.display = "none";
    ayuda.innerHTML = "";

    if (retoActual.nivel === "basico") {
        pistas.style.display = "block";
        titulo.innerHTML = "Marca la pista que describe el caso";
    } else if (retoActual.nivel === "intermedio") {
        pistas.style.display = "block";
        titulo.innerHTML = "Usa las pistas y luego selecciona la estructura";
    } else {
        pistas.style.display = "none";
    }
}

function usarPista(check) {
    document.querySelectorAll('input[name="pista"]').forEach(chk => {
        if (chk !== check) chk.checked = false;
    });

    const ayuda = document.getElementById("pistaAyuda");

    if (!check.checked) {
        ayuda.style.display = "none";
        ayuda.innerHTML = "";
        return;
    }

    if (retoActual.nivel === "basico") {
        document.getElementById("estructuraSelect").value = check.value;
        validar();
        ayuda.style.display = "block";
        ayuda.innerHTML = "En este nivel la pista completa la estructura para que observes la relación.";
    } else if (retoActual.nivel === "intermedio") {
        ayuda.style.display = "block";
        ayuda.innerHTML = "La pista señala una posible estructura. Ahora debes seleccionarla en el desplegable.";
    }
}

function validar() {
    const opcion = document.getElementById("estructuraSelect").value;
    const feedback = document.getElementById("feedback");

    if (opcion === "") {
        feedback.style.display = "none";
        document.getElementById("botones").style.display = "none";
        return;
    }

    feedback.style.display = "block";

    if (opcion === retoActual.correcta) {
        feedback.className = "feedback ok";
        feedback.innerHTML = "😊 " + retoActual.acierto;
        document.getElementById("botones").style.display = "flex";
        marcarResuelto();
    } else {
        feedback.className = "feedback error";
        feedback.innerHTML = "😟 No corresponde. Revisa si el caso necesita decidir, repetir con contador, repetir por condición, validar después de pedir un dato o elegir entre opciones.";
        document.getElementById("botones").style.display = "none";
        document.getElementById("panel").style.display = "none";
        document.getElementById("panel").innerHTML = "";
    }
}

function marcarResuelto() {
    const id = botonActual.getAttribute("data-id");
    const nivel = retoActual.nivel;
    resueltos[nivel].add(id);
    botonActual.classList.add("resuelto");

    if (resueltos.basico.size === 5) {
        document.getElementById("nivelIntermedio").classList.remove("oculto");
        mostrarAviso("Nivel intermedio disponible.");
    }

    if (resueltos.intermedio.size === 5) {
        document.getElementById("nivelAvanzado").classList.remove("oculto");
        mostrarAviso("Nivel avanzado disponible.");
    }
}

function mostrarAviso(texto) {
    const aviso = document.getElementById("avisoNivel");
